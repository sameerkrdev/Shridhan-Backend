generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Society {
  id                                String                             @id @default(uuid())
  name                              String                             @unique
  country                           String
  state                             String
  city                              String
  zipcode                           String
  logoUrl                           String
  status                            SocietyStatus                      @default(CREATED)
  isDeleted                         Boolean                            @default(false)
  deletedAt                         DateTime?
  createdBy                         String
  createdAt                         DateTime                           @default(now())
  updatedAt                         DateTime                           @updatedAt
  customers                         Customer[]
  fixedDepositProjectType           FixedDepositProjectType[]
  memberships                       Membership[]
  monthlyInterestSchemeProjectTypes MonthlyInterestSchemeProjectType[]
  recurringDepositProjectType       RecurringDepositProjectType[]
  activities                        ActivityLog[]
  planSettings                      SocietyPlanSettings?
  roles                             SocietyRole[]
  subscriptions                     Subscription[]

  @@index([status])
}

model ActivityLog {
  id                 String             @id @default(uuid())
  societyId          String
  entityType         ActivityEntityType
  entityId           String
  actionType         ActivityActionType
  actorMembershipId  String?
  actorName          String
  actorPhone         String
  actorRoleName      String
  metadata           Json?
  createdAt          DateTime           @default(now())
  society            Society            @relation(fields: [societyId], references: [id])

  @@index([societyId, entityType, entityId, createdAt])
  @@index([societyId, createdAt])
}

model SocietyPlanSettings {
  id                            String    @id @default(uuid())
  societyId                     String    @unique
  trialStartDate                DateTime?
  trialEndDate                  DateTime?
  developerOverrideEnabled      Boolean   @default(false)
  setupFeeEnabled               Boolean   @default(true)
  setupFeeAmount                Decimal   @default(50000) @db.Decimal(14, 2)
  setupFeePaid                  Boolean   @default(false)
  setupFeePaidAt                DateTime?
  setupFeePaymentId             String?   @unique
  customOneTimeFeeEnabled       Boolean   @default(false)
  customOneTimeFeeAmount        Decimal?  @db.Decimal(14, 2)
  customOneTimeFeeWaived        Boolean   @default(false)
  customSubscriptionEnabled     Boolean   @default(false)
  customSubscriptionAmount      Decimal?  @db.Decimal(14, 2)
  customSubscriptionWaived      Boolean   @default(false)
  billingPolicySetByDeveloperId String?
  billingPolicySetReason        String?
  billingPolicyUpdatedAt        DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  society                       Society   @relation(fields: [societyId], references: [id])

  @@index([societyId])
  @@index([setupFeePaid])
}

model Subscription {
  id                  String                        @id @default(uuid())
  planId              String
  customerId          String
  razorpaySubId       String                        @unique
  planName            String
  planAmount          Decimal                       @db.Decimal(14, 2)
  billingPeriod       Int
  currency            String                        @default("INR")
  oneTimeAddonApplied Boolean                       @default(false)
  oneTimeAddonAmount  Decimal?                      @db.Decimal(14, 2)
  status              SubscriptionStatus
  startDate           DateTime
  nextBillingAt       DateTime
  previousBillingAt   DateTime?
  isActive            Boolean                       @default(true)
  mandateStatus       MandateStatus                 @default(PENDING)
  mandateUpdatedAt    DateTime?
  retryCount          Int                           @default(0)
  isInGrace           Boolean                       @default(false)
  graceEndDate        DateTime?
  societyId           String
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  society             Society                       @relation(fields: [societyId], references: [id])
  transitionLogs      SubscriptionStateTransition[]
  transactions        SubscriptionTransaction[]

  @@index([societyId])
  @@index([razorpaySubId])
  @@index([status])
}

model SubscriptionTransaction {
  id                String                        @id @default(uuid())
  amount            Decimal                       @db.Decimal(14, 2)
  status            SubscriptionTransactionStatus @default(PENDING)
  isPaid            Boolean                       @default(false)
  razorpayPaymentId String?                       @unique
  razorpayRefundId  String?                       @unique
  billingDate       DateTime
  paymentDate       DateTime?
  refundDate        DateTime?
  paymentMethod     PaymentMethod?
  paymentCycleCount Int
  subscriptionId    String
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  subscription      Subscription                  @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([razorpayPaymentId])
  @@index([status])
}

model SubscriptionStateTransition {
  id             String             @id @default(uuid())
  subscriptionId String
  fromStatus     SubscriptionStatus
  toStatus       SubscriptionStatus
  reason         String
  createdAt      DateTime           @default(now())
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([createdAt])
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String         @unique
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  refreshTokens RefreshToken[]

  @@index([phone])
  @@index([email])
}

model Membership {
  id        String      @id @default(cuid())
  userId    String
  societyId String
  roleId    String
  status    String      @default("active")
  deletedAt DateTime?
  joinedAt  DateTime    @default(now())
  customers Customer[]
  role      SocietyRole @relation(fields: [roleId], references: [id])
  society   Society     @relation(fields: [societyId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, societyId])
  @@index([userId])
  @@index([societyId])
}

model SocietyRole {
  id          String       @id @default(cuid())
  societyId   String
  name        String
  isSystem    Boolean      @default(false)
  permissions String[]
  createdAt   DateTime     @default(now())
  memberships Membership[]
  society     Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, name])
  @@index([societyId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  deviceId  String?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Customer {
  id                String                  @id @default(uuid())
  fullName          String
  phone             String
  email             String?
  address           String?
  aadhaar           String?
  pan               String?
  accountType       CustomerAccountType
  societyId         String
  membershipId      String
  isDeleted         Boolean                 @default(false)
  deletedAt         DateTime?
  createdBy         String
  updatedBy         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  membership        Membership              @relation(fields: [membershipId], references: [id])
  society           Society                 @relation(fields: [societyId], references: [id])
  fixDeposits       FixDeposit[]
  loans             Loan[]
  monthlySchemes    MonthlyInterestScheme[]
  nominees          Nominee[]
  recurringDeposits RecurringDeposit[]

  @@index([societyId])
  @@index([membershipId])
  @@index([phone])
}

model Nominee {
  id         String    @id @default(uuid())
  name       String
  phone      String
  address    String?
  email      String?
  relation   String?
  aadhaar    String?
  pan        String?
  customerId String
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdBy  String
  updatedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([phone])
}

model FixedDepositProjectType {
  id                          String                     @id @default(uuid())
  name                        String
  minimumAmount               Decimal                    @default(0) @db.Decimal(14, 2)
  maturityMultiple            Decimal                    @db.Decimal(14, 2)
  maturityAmountPerHundred    Decimal                    @db.Decimal(14, 2)
  maturityCalculationMethod   MaturityCalculationMethod  @default(PER_RS_100)
  duration                    Int
  version                  Int          @default(1)
  isArchived               Boolean      @default(false)
  societyId                String
  isDeleted                Boolean      @default(false)
  deletedAt                DateTime?
  createdBy                String
  updatedBy                String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  fixDeposits              FixDeposit[]
  society                  Society      @relation(fields: [societyId], references: [id])

  @@index([societyId])
  @@index([name])
}

model FixDeposit {
  id              String                  @id @default(uuid())
  principalAmount Decimal                 @db.Decimal(14, 2)
  startDate       DateTime
  maturityAmount  Decimal                 @db.Decimal(14, 2)
  maturityDate    DateTime
  status          ServiceStatus
  projectTypeId   String
  customerId      String
  isDeleted       Boolean                 @default(false)
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  customer        Customer                @relation(fields: [customerId], references: [id])
  projectType     FixedDepositProjectType @relation(fields: [projectTypeId], references: [id])
  transactions    FixDepositTransaction[]
  documents       ServiceDocument[]

  @@index([projectTypeId])
  @@index([customerId])
  @@index([maturityDate])
}

model FixDepositTransaction {
  id            String          @id @default(uuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2)
  month         Int?
  paymentMethod PaymentMethod?
  transactionId String?
  upiId         String?
  chequeNumber  String?
  bankName      String?
  fixDepositId  String
  isDeleted     Boolean         @default(false)
  deletedAt     DateTime?
  createdBy     String
  updatedBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  fixDeposit    FixDeposit      @relation(fields: [fixDepositId], references: [id])

  @@index([fixDepositId])
  @@index([transactionId])
  @@index([createdAt])
}

model ServiceDocument {
  id                      String                 @id @default(uuid())
  serviceType             ServiceType
  serviceEntityId         String
  fileName                String
  displayName             String
  objectKey               String                 @unique
  fileUrl                 String
  contentType             String?
  sizeBytes               Int?
  isUploaded              Boolean                @default(false)
  fixDepositId            String?
  recurringDepositId      String?
  monthlyInterestSchemeId String?
  loanId                  String?
  isDeleted               Boolean                @default(false)
  deletedAt               DateTime?
  createdBy               String
  updatedBy               String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  fixDeposit              FixDeposit?            @relation(fields: [fixDepositId], references: [id])
  loan                    Loan?                  @relation(fields: [loanId], references: [id])
  monthlyInterestScheme   MonthlyInterestScheme? @relation(fields: [monthlyInterestSchemeId], references: [id])
  recurringDeposit        RecurringDeposit?      @relation(fields: [recurringDepositId], references: [id])

  @@index([fixDepositId])
  @@index([isUploaded])
  @@index([serviceType, serviceEntityId])
  @@index([recurringDepositId])
  @@index([monthlyInterestSchemeId])
  @@index([loanId])
}

model MonthlyInterestSchemeProjectType {
  id                             String                  @id @default(uuid())
  name                           String
  minimumAmount                  Decimal                 @default(0) @db.Decimal(14, 2)
  calculationMethod              MisCalculationMethod   @default(MONTHLY_PAYOUT_PER_HUNDRED)
  monthlyPayoutAmountPerHundred  Decimal?               @db.Decimal(14, 2)
  annualInterestRate             Decimal?                @db.Decimal(7, 4)
  duration                       Int
  version                        Int                     @default(1)
  isArchived                     Boolean                 @default(false)
  societyId                      String
  isDeleted                      Boolean                 @default(false)
  deletedAt                      DateTime?
  createdBy                      String
  updatedBy                      String?
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
  monthlyInterestScheme          MonthlyInterestScheme[]
  society                        Society                 @relation(fields: [societyId], references: [id])

  @@index([societyId])
  @@index([name])
}

model MonthlyInterestScheme {
  id              String                             @id @default(uuid())
  depositAmount   Decimal                            @default(0) @db.Decimal(14, 2)
  monthlyInterest Decimal                            @default(0) @db.Decimal(14, 2)
  startDate       DateTime
  maturityAmount  Decimal                            @db.Decimal(14, 2)
  maturityDate    DateTime
  status          ServiceStatus
  projectTypeId   String
  customerId      String
  isDeleted       Boolean                            @default(false)
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime                           @default(now())
  updatedAt       DateTime                           @updatedAt
  customer        Customer                           @relation(fields: [customerId], references: [id])
  projectType     MonthlyInterestSchemeProjectType   @relation(fields: [projectTypeId], references: [id])
  transactions    MonthlyInterestSchemeTransaction[]
  documents       ServiceDocument[]

  @@index([projectTypeId])
  @@index([customerId])
}

model MonthlyInterestSchemeTransaction {
  id                      String                @id @default(uuid())
  isExpected              Boolean               @default(false)
  month                   Int?
  amount                  Decimal               @db.Decimal(14, 2)
  type                    TransactionType
  paymentMethod           PaymentMethod?
  transactionId           String?
  upiId                   String?
  chequeNumber            String?
  bankName                String?
  monthlyInterestSchemeId String
  isDeleted               Boolean               @default(false)
  deletedAt               DateTime?
  createdBy               String
  updatedBy               String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  monthlyInterestScheme   MonthlyInterestScheme @relation(fields: [monthlyInterestSchemeId], references: [id])

  @@index([monthlyInterestSchemeId])
  @@index([transactionId])
  @@index([monthlyInterestSchemeId, month, isExpected])
}

model RecurringDepositProjectType {
  id                   String                 @id @default(uuid())
  name                 String
  duration             Int
  minimumMonthlyAmount Decimal                @db.Decimal(14, 2)
  maturityPerHundred   Decimal                @db.Decimal(14, 2)
  fineCalculationMethod RdFineCalculationMethod @default(FIXED_PER_STREAK_UNIT)
  fixedOverdueFineAmount Decimal?             @db.Decimal(14, 2)
  fineRatePerHundred   Decimal                @db.Decimal(14, 2)
  graceDays            Int                    @default(0)
  penaltyMultiplier    Decimal?           @db.Decimal(14, 2)
  penaltyStartMonth    Int?
  version              Int                @default(1)
  isArchived           Boolean            @default(false)
  societyId            String
  isDeleted            Boolean            @default(false)
  deletedAt            DateTime?
  createdBy            String
  updatedBy            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  recurringDeposits    RecurringDeposit[]
  society              Society            @relation(fields: [societyId], references: [id])

  @@index([societyId])
  @@index([name])
}

model RecurringDeposit {
  id                         String                        @id @default(uuid())
  monthlyAmount              Decimal                       @db.Decimal(14, 2)
  totalPrincipalExpected     Decimal                       @db.Decimal(14, 2)
  expectedMaturityPayout     Decimal                       @db.Decimal(14, 2)
  maturityPerHundredSnapshot Decimal                       @db.Decimal(14, 2)
  fineCalculationMethodSnapshot RdFineCalculationMethod
  fixedOverdueFineAmountSnapshot Decimal?                  @db.Decimal(14, 2)
  fineRatePerHundredSnapshot Decimal                       @db.Decimal(14, 2)
  graceDaysSnapshot          Int
  penaltyMultiplierSnapshot  Decimal?                      @db.Decimal(14, 2)
  penaltyStartMonthSnapshot  Int?
  startDate                  DateTime
  maturityDate               DateTime
  status                     ServiceStatus
  projectTypeId              String
  customerId                 String
  isDeleted                  Boolean                       @default(false)
  deletedAt                  DateTime?
  createdBy                  String
  updatedBy                  String?
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt
  customer                   Customer                      @relation(fields: [customerId], references: [id])
  projectType                RecurringDepositProjectType   @relation(fields: [projectTypeId], references: [id])
  installments               RecurringDepositInstallment[]
  transactions               RecurringDepositTransaction[]
  fineWaiveRequests          RdFineWaiveRequest[]
  documents                  ServiceDocument[]

  @@index([projectTypeId])
  @@index([customerId])
}

model RecurringDepositInstallment {
  id                 String                              @id @default(uuid())
  recurringDepositId String
  monthIndex         Int
  dueDate            DateTime
  principalAmount    Decimal                             @db.Decimal(14, 2)
  paidPrincipal      Decimal                             @default(0) @db.Decimal(14, 2)
  deferredFineAccrued Decimal                            @default(0) @db.Decimal(14, 2)
  status             RecurringDepositInstallmentStatus   @default(PENDING)
  isDeleted          Boolean                             @default(false)
  deletedAt          DateTime?
  createdBy          String
  updatedBy          String?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt
  recurringDeposit   RecurringDeposit                    @relation(fields: [recurringDepositId], references: [id])
  paymentAllocations RecurringDepositPaymentAllocation[]

  @@unique([recurringDepositId, monthIndex])
  @@index([recurringDepositId, dueDate])
}

model RecurringDepositTransaction {
  id                 String                              @id @default(uuid())
  recurringDepositId String
  /// Total payment amount (principal + fine portions).
  amount             Decimal                             @db.Decimal(14, 2)
  principalAmount    Decimal                             @default(0) @db.Decimal(14, 2)
  fineAmount         Decimal                             @default(0) @db.Decimal(14, 2)
  type               RecurringDepositTransactionType
  paymentMethod      PaymentMethod?
  transactionId      String?
  upiId              String?
  chequeNumber       String?
  bankName           String?
  isDeleted          Boolean                             @default(false)
  deletedAt          DateTime?
  createdBy          String
  updatedBy          String?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt
  allocations        RecurringDepositPaymentAllocation[]
  recurringDeposit   RecurringDeposit                    @relation(fields: [recurringDepositId], references: [id])

  @@index([recurringDepositId])
  @@index([transactionId])
}

model RecurringDepositPaymentAllocation {
  id               String                      @id @default(uuid())
  transactionId    String
  installmentId    String
  principalApplied Decimal                     @db.Decimal(14, 2)
  fineApplied      Decimal                     @default(0) @db.Decimal(14, 2)
  waivedFineAmount Decimal                     @default(0) @db.Decimal(14, 2)
  waivedByRequestId String?
  waivedApprovedByMembershipId String?
  createdAt        DateTime                    @default(now())
  installment      RecurringDepositInstallment @relation(fields: [installmentId], references: [id])
  transaction      RecurringDepositTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  waiveRequest     RdFineWaiveRequest?         @relation(fields: [waivedByRequestId], references: [id])

  @@index([transactionId])
  @@index([installmentId])
  @@index([waivedByRequestId])
}

model RdFineWaiveRequest {
  id                        String                         @id @default(uuid())
  recurringDepositId        String
  requestedByMembershipId   String
  scopeType                 RdFineWaiveScopeType
  reason                    String?
  expiresAt                 DateTime
  status                    RdFineWaiveRequestStatus      @default(PENDING)
  reduceFromMaturity        Boolean                        @default(false)
  approvedByMembershipId    String?
  approvedAt                DateTime?
  rejectedByMembershipId    String?
  rejectedAt                DateTime?
  rejectionReason           String?
  invalidationReason        RdFineWaiveInvalidationReason?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  recurringDeposit          RecurringDeposit               @relation(fields: [recurringDepositId], references: [id], onDelete: Cascade)
  months                    RdFineWaiveRequestMonth[]
  paymentAllocations        RecurringDepositPaymentAllocation[]

  @@index([recurringDepositId, status, expiresAt])
  @@index([requestedByMembershipId])
}

model RdFineWaiveRequestMonth {
  id                 String             @id @default(uuid())
  requestId          String
  monthIndex         Int
  waivedFineAmount   Decimal            @default(0) @db.Decimal(14, 2)
  createdAt          DateTime           @default(now())
  request            RdFineWaiveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, monthIndex])
  @@index([requestId])
}

model Loan {
  id              String            @id @default(uuid())
  principalAmount Decimal           @db.Decimal(14, 2)
  interestRate    Decimal           @db.Decimal(14, 2)
  fineBaseRate    Decimal           @db.Decimal(14, 2)
  fineCurrentRate Decimal           @db.Decimal(14, 2)
  fineAccumulated Decimal           @default(0) @db.Decimal(14, 2)
  totalPaid       Decimal           @default(0) @db.Decimal(14, 2)
  startDate       DateTime
  dueDate         DateTime
  status          LoanStatus
  customerId      String
  isDeleted       Boolean           @default(false)
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customer        Customer          @relation(fields: [customerId], references: [id])
  emi             LoanEmi[]
  documents       ServiceDocument[]

  @@index([customerId])
}

model LoanEmi {
  id         String        @id @default(uuid())
  amount     Decimal       @db.Decimal(14, 2)
  fineAmount Decimal       @default(0) @db.Decimal(14, 2)
  dueDate    DateTime
  paidDate   DateTime?
  status     LoanEmiStatus
  loanId     String
  isDeleted  Boolean       @default(false)
  deletedAt  DateTime?
  createdBy  String
  updatedBy  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  loan       Loan          @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAYMENT_FAILED
  PENDING_ACTIVATION
}

enum MandateStatus {
  ACTIVE
  PENDING
  FAILED
}

enum SubscriptionTransactionStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}

enum LoanStatus {
  ONGOING
  COMPLETED
}

enum LoanEmiStatus {
  PENDING
  PAID
}

enum ServiceStatus {
  PENDING_DEPOSIT
  ACTIVE
  COMPLETED
  CLOSED
}

enum TransactionType {
  CREDIT
  PAYOUT
  DEPOSIT
  INTEREST_PAYOUT
  PRINCIPAL_RETURN
}

enum RecurringDepositTransactionType {
  CREDIT
  PAYOUT
}

enum RecurringDepositInstallmentStatus {
  PENDING
  OVERDUE
  PARTIAL
  PAID
}

enum ServiceType {
  FIX_DEPOSIT
  RECURING_DEPOSIT
  MONTHLY_INTEREST_SCHEME
}

enum SocietyStatus {
  CREATED
  RAZORPAY_PENDING
  ACTIVE
}

enum PaymentMethod {
  UPI
  CASH
  CHEQUE
}

enum CustomerAccountType {
  LOAN
  FIXED_DEPOSIT
  MONTHLY_INTEREST_SCHEME
  RECURING_DEPOSIT
}

enum MaturityCalculationMethod {
  PER_RS_100
  MULTIPLE_OF_PRINCIPAL
}

enum MisCalculationMethod {
  MONTHLY_PAYOUT_PER_HUNDRED
  ANNUAL_INTEREST_RATE
}

enum RdFineCalculationMethod {
  FIXED_PER_STREAK_UNIT
  PROPORTIONAL_PER_HUNDRED
}

enum RdFineWaiveScopeType {
  ALL
  SELECTED
}

enum RdFineWaiveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  INVALIDATED
}

enum RdFineWaiveInvalidationReason {
  PAID_ALREADY
  MANUAL_REJECT
  EXPIRED
}

enum ActivityEntityType {
  FD_PROJECT_TYPE
  MIS_PROJECT_TYPE
  RD_PROJECT_TYPE
  FD_ACCOUNT
  MIS_ACCOUNT
  RD_ACCOUNT
}

enum ActivityActionType {
  CREATED
  UPDATED
  DELETED
  STATUS_UPDATED
  TRANSACTION_ADDED
  DEPOSIT_ADDED
  INTEREST_PAID
  PRINCIPAL_RETURNED
  PAYMENT_ADDED
  WAIVE_REQUEST_CREATED
  WAIVE_REQUEST_APPROVED
  WAIVE_REQUEST_REJECTED
  WAIVE_REQUEST_INVALIDATED
  WAIVED_FINE_APPLIED_IN_PAYMENT
  WITHDRAWN
  DOCUMENT_UPLOAD_COMPLETED
  DOCUMENT_UPDATED
  DOCUMENT_DELETED
}
